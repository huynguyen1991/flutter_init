{
  "name": "flutter_init",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:unit": "vitest run --config vitest.config.ts tests/unit/",
    "test:integration": "vitest run --config vitest.config.ts tests/integration/",
    "test:layer1": "npm run test:unit && npm run test:integration",
    "test:layer2": "bun scripts/validate-dart.ts --mode critical",
    "test:tier3": "bun tests/e2e/run-matrix.ts",
    "test:preflight": "npm run test:layer1 && npm run test:layer2"
  },
